<%- layout("./layouts/boilerplate") -%>
<div class="row align-items-center login-form-container p-3">
<form
  class=" col-10 offset-1 col-sm-7 col-md-6 col-lg-4 offset-sm-3 offset-lg-4 my-5 needs-validation border rounded-2 p-4 login-form border-3 border-dark"
  action="/login"
  method="post"
  novalidate>
  <h2>Login</h2>
  <div class="mb-3">
    <label for="username" class="form-label">Username</label>
    <input
      type="text"
      class="form-control"
      id="username"
      aria-describedby="username"
      name="username"
      required />
    <div id="username" class="form-text">
      We'll never share your email with anyone else.
    </div>
  </div>
  <div>
    <label for="exampleInputPassword1" class="form-label">Password</label>
    <input
      type="password"
      class="form-control"
      id="exampleInputPassword1"
      name="password"
      required />
  </div>
  <div class="mb-3 form-check">
    <input type="checkbox" class="form-check-input" id="exampleCheck1" />
    <label class="form-check-label" for="exampleCheck1">Check me out</label>
  </div>
  <button type="submit" class="btn btn-primary">Login</button>
</form>
</div>




