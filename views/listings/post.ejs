<% layout('./layouts/boilerplate') -%>
<h3 class="text-center pt-2">Create new List</h3>
<br />
<form
  class="row g-3 px-4 needs-validation"
  method="post"
  action="/listings"
  enctype="multipart/form-data"
  novalidate>
  <div class="col-10 col-sm-10 offset-1 col-md-11 offset-md-1 col-lg-8 offset-lg-3">
    <div class="row">
      <div class="col-12 col-sm-6 col-md-5 my-2">
        <label for="title4" class="form-label">Title</label>
        <input
          type="text"
          class="form-control"
          id="title4"
          placeholder="enter title"
          name="listing[title]"
          required />
        <div class="invalid-feedback">Please provide a valid title.</div>
        <div class="valid-feedback">Looks good</div>
      </div>

      <div class="col-12 col-sm-6 col-md-4  my-2">
        <label for="image4" class="form-label">Image</label>
        <input
          type="file"
          class="form-control"
          id="image4"
          name="listing[image]" required/>
      </div>

      <div class="col-12 col-md-9 my-2">
        <label for="description4" class="form-label">Description</label>
        <textarea
          name="listing[description]"
          id="description4"
          placeholder="enter description"
          class="form-control"
          rows="3"
          required></textarea>
        <div class="invalid-feedback">Please provide a valid Description.</div>
        <div class="valid-feedback">Looks good</div>
      </div>

      

      <div class="col-12 d-sm-flex align-items-md-center gap-sm-5">
        <div class="col-12 col-sm-5 col-md-5  my-2">
          <label for="price4" class="form-label">Price</label>
          <input
            type="text"
            class="form-control"
            id="price4"
            placeholder="enter price"
            name="listing[price]"
            required />
          <div class="invalid-feedback">Please provide a valid price.</div>
          <div class="valid-feedback">Looks good</div>
        </div>
        <div class="col-12 col-sm-4 col-md-4 mt-sm-4 py-2">
          <label for="category">Choose Category</label>
          <select name="listing[category]" id="category" required>
            <option value="Mountains">Mountains</option>
            <option value="Beach">Beach</option>
            <option value="Camp">camp</option>
            <option value="Apartment">Apartment</option>
            <option value="Villa">villa</option>
            <option value="List">loft</option>
            <option value="Other">other</option>
          </select>
        </div>
      </div>

      <div class="col-12 col-sm-6 col-md-4  my-2">
        <label for="country4" class="form-label">country</label>
        <input
          type="text"
          class="form-control"
          id="country4"
          placeholder="enter country"
          name="listing[country]"
          required />
        <div class="invalid-feedback">Please provide a valid country.</div>
        <div class="valid-feedback">Looks good</div>
      </div>

      <div class="col-12 col-sm-6 col-md-5  my-2">
        <label for="location4" class="form-label">location</label>
        <input
          type="text"
          class="form-control"
          id="location4"
          placeholder="enter location"
          name="listing[location]"
          required />
        <div class="invalid-feedback">Please provide a valid location.</div>
        <div class="valid-feedback">Looks good</div>
      </div>

      <div class="col-12 my-4">
        <button type="submit" class="btn btn-primary">Post</button>
      </div>
    </div>
  </div>
</form>
